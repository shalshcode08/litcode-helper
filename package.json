{
  "name": "litcode-helper",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "description": "A personal browser extension that logs accepted LeetCode solutions to GitHub.",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "package": "pnpm run build && cd dist && zip -r ../litcode-helper.zip .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turndown": "^7.2.0",
    "webextension-polyfill": "^0.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.300",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
