---
type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
};

const {
  title = "Litcode Helper",
  description = "Litcode Helper saves accepted LeetCode solutions to your own GitHub repository.",
  canonicalPath = "/"
} = Astro.props;
const siteUrl = "https://litcode-helper.vercel.app";
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Litcode Helper" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <main>
      <nav>
        <a class="brand" href="/">
          <span>LH</span>
          Litcode Helper
        </a>
      </nav>

      <slot />

      <footer>
        <span>Litcode Helper</span>
        <a href="/privacy/">Privacy Policy</a>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  :root {
    background: #f8f4e9;
    color: #16130f;
    font-family: Georgia, Cambria, "Times New Roman", Times, serif;
    line-height: 1.45;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    background: #f8f4e9;
  }

  main {
    background:
      linear-gradient(135deg, rgba(34, 93, 82, 0.08), transparent 34%),
      #f8f4e9;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    padding: 24px clamp(18px, 6vw, 80px);
  }

  nav,
  footer,
  .wrap {
    max-width: 960px;
    width: 100%;
  }

  nav,
  footer,
  .wrap {
    margin-left: auto;
    margin-right: auto;
  }

  nav,
  footer {
    align-items: center;
    display: flex;
    justify-content: space-between;
  }

  .brand,
  .nav-link,
  footer,
  .button,
  .eyebrow,
  .lede,
  .points,
  .privacy {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .brand,
  .nav-link,
  footer a {
    color: inherit;
    text-decoration: none;
  }

  .brand {
    align-items: center;
    display: inline-flex;
    font-weight: 800;
    gap: 10px;
  }

  .brand span {
    align-items: center;
    background: #225d52;
    border: 2px solid #16130f;
    box-shadow: 3px 3px 0 #16130f;
    color: #fff9ea;
    display: inline-flex;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    height: 36px;
    justify-content: center;
    width: 36px;
  }

  .nav-link,
  footer {
    color: #4d463c;
    font-size: 14px;
    font-weight: 700;
  }

  footer {
    border-top: 2px solid rgba(22, 19, 15, 0.2);
    margin-top: auto;
    padding: 16px 0 2px;
    width: 100%;
  }

  h1,
  h2,
  p {
    margin: 0;
  }

  @media (max-width: 640px) {
    footer {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
