---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Litcode Helper - Save LeetCode Solutions to GitHub"
  description="A minimal browser extension that saves accepted LeetCode solutions into your own GitHub repository."
>
  <section class="wrap hero">
    <h1>Save accepted LeetCode solutions to GitHub.</h1>
    <p class="lede">
      Litcode Helper watches for accepted submissions and writes the problem link, statement, and
      code into your own repository, organized by date.
    </p>

    <div class="actions">
      <a class="button" href="#">Chrome Web Store</a>
      <a class="button secondary" href="https://github.com/new?name=leetcode-helper&auto_init=1">
        Create repo
      </a>
    </div>

    <div class="points" aria-label="Product highlights">
      <p><strong>Daily log.</strong> Files are grouped in folders by solve date.</p>
      <p><strong>Your GitHub.</strong> Uses the repo and token you configure.</p>
      <p><strong>No backend.</strong> No analytics, ads, or hosted server.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: clamp(38px, 7vh, 70px) 0 16px;
  }

  h1 {
    font-size: clamp(42px, 6.2vw, 66px);
    letter-spacing: 0;
    line-height: 1;
    max-width: 780px;
  }

  .lede {
    color: #4d463c;
    font-size: 18px;
    margin-top: 18px;
    max-width: 680px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .button {
    background: #e6ac4e;
    border: 2px solid #16130f;
    box-shadow: 4px 4px 0 #16130f;
    color: #16130f;
    font-size: 14px;
    font-weight: 850;
    padding: 13px 16px;
    text-decoration: none;
  }

  .button.secondary {
    background: #fffdf7;
  }

  .points {
    border-top: 2px solid #16130f;
    display: grid;
    gap: 9px;
    margin-top: 28px;
    max-width: 680px;
    padding-top: 18px;
  }

  .points p {
    color: #3b362f;
    font-size: 15px;
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 58px;
    }

    h1 {
      font-size: 42px;
    }

    .lede {
      font-size: 17px;
    }
  }
</style>
